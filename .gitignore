# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local browser/MCP state may contain auth tokens
.playwright-mcp/

# Heretic / model artifacts (large, regenerable)
# Track small transcripts + reports inside results/; ignore heavy model files
*.gguf
*.safetensors
*.bin
*.pt
*.pth
checkpoints/
abliterated-*/
models/
hf_cache/
logs/
nohup.out
*.log

# Everything else under results/ is ignored by default
# Use ** (not *) so nested files are caught, not just top-level items
results/**
# ...except the named small reproducible artifacts we want committed
!results/.gitkeep
!results/**/
!results/**/REPORT.md
!results/**/NOTES.md
!results/**/prompt.txt
!results/**/*_prompt.txt
!results/**/benign.txt
!results/**/transcript*.txt
!results/**/transcript_*.txt
!results/**/stock.txt
!results/**/heretic.txt
!results/**/scene.txt
!results/**/story_only.txt
!results/**/chapter_1.txt
!results/**/human_readable*.txt
!results/**/human_readable*.md
!results/**/summary.json
!results/**/metadata.json
!results/**/response.json
!results/**/config*.toml

# Full heretic upstream source — clone separately, see heretic/SOURCE.md
# Convert to a git submodule when reproducibility matters:
#   git submodule add https://github.com/p-e-w/heretic heretic
heretic/

# Ollama
Modelfile.local

# OS
.DS_Store
.AppleDouble
.LSOverride

