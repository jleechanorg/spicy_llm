# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Heretic / model artifacts (large, regenerable)
# Track small transcripts + reports inside results/; ignore heavy model files
*.gguf
*.safetensors
*.bin
*.pt
*.pth
checkpoints/
abliterated-*/
models/
hf_cache/
logs/
nohup.out
*.log

# Everything else under results/ is ignored by default
# Use ** (not *) so nested files are caught, not just top-level items
results/**
# ...except the small reproducible artifacts we want committed
# Allow all text/markdown/json artifacts (not model binaries) in any subdir
!results/.gitkeep
!results/**/
!results/**/*.txt
!results/**/*.md
!results/**/*.json
!results/**/config*.toml

# Full heretic upstream source — clone separately, see heretic/SOURCE.md
# Convert to a git submodule when reproducibility matters:
#   git submodule add https://github.com/p-e-w/heretic heretic
heretic/

# Ollama
Modelfile.local

# OS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.idea/
.vscode/
*.swp
*.swo
